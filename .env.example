# =============================================================================
# GTM INTELLIGENCE AGENT — ENVIRONMENT VARIABLES
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# All 14 keys below are required for the full system to run end-to-end.
# Most have generous free tiers; see README.md for sign-up links.
# =============================================================================

# --- 1. Anthropic Claude (LLM: Haiku for classification, Sonnet for synthesis)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 2. Supabase URL (project REST endpoint)
# Get from: Supabase project settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# --- 3. Supabase service role key (server-side writes, bypasses RLS)
# Get from: Supabase project settings → API → service_role secret
# DO NOT expose this in any client-side code. Server / n8n only.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxx

# --- 4. Airtable Personal Access Token (mock CRM)
# Get from: https://airtable.com/create/tokens (scope: data.records:read, data.records:write, schema.bases:read)
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 5. Airtable Base ID (the GTM-Intel mock CRM base)
# Get from: https://airtable.com/api → select your base → first ID in URL (starts `app...`)
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# --- 6. Notion Internal Integration Secret (battlecards + run log)
# Get from: https://www.notion.so/my-integrations → New integration → Internal
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 7. Notion Battlecards database ID (32-char id from the database URL)
# Get from: open the battlecards DB in Notion → copy the part of the URL between the last `/` and `?v=`
NOTION_BATTLECARD_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 8. Slack Bot User OAuth Token (posts digests + deal cards)
# Get from: https://api.slack.com/apps → your app → OAuth & Permissions → "Bot User OAuth Token"
# Scopes required: chat:write, commands, channels:read, chat:write.public
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx

# --- 9. Slack Incoming Webhook URL (fallback / simple posts)
# Get from: Slack app → Incoming Webhooks → Add New Webhook to Workspace
# Format example (do not paste this — replace with your own):
#   https://hooks.slack.com/services/<TEAM_ID>/<CHANNEL_ID>/<TOKEN>
SLACK_WEBHOOK_URL=__REPLACE_WITH_YOUR_SLACK_WEBHOOK_URL__

# --- 9b. Slack channel-specific webhooks used by the n8n workflows
# Same provenance as above; one webhook per channel keeps routing simple in n8n.
# #competitive-intel — weekly digest + HIGH-signal approval cards (Scenario A)
SLACK_WEBHOOK_COMPETITIVE_INTEL=__REPLACE_WITH_COMPETITIVE_INTEL_CHANNEL_WEBHOOK__
# #deals — deal enrichment notifications (Scenario B; wired up in Session 4)
SLACK_WEBHOOK_DEALS=__REPLACE_WITH_DEALS_CHANNEL_WEBHOOK__

# --- 10. Firecrawl API key (web scraping, returns clean markdown)
# Get from: https://www.firecrawl.dev/app/api-keys (free: 500 pages/month)
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 11. Clearbit API key (company enrichment — overview, headcount, tech stack)
# Get from: https://dashboard.clearbit.com/api (free tier: 50 req/month on personal plan)
# (Optional: Scenario B uses Hunter.io — see HUNTER_API_KEY below — and Clearbit only as a fallback.)
CLEARBIT_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 11b. Hunter.io API key (company lookup by domain — used by Scenario B)
# Get from: https://hunter.io/api-keys (free: 25 req/month, paid plans for more)
HUNTER_API_KEY=__REPLACE_WITH_YOUR_HUNTER_IO_API_KEY__

# --- 12. Crunchbase Basic API key (funding rounds, investors)
# Get from: https://data.crunchbase.com/docs/using-the-api → request basic key
CRUNCHBASE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 13. HuggingFace API token (embeddings via sentence-transformers/all-MiniLM-L6-v2)
# Get from: https://huggingface.co/settings/tokens (role: read; free Inference API)
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 14. Langfuse keys (LLM observability — token usage, cost, prompt versions)
# Get from: https://cloud.langfuse.com → Project settings → API Keys
# Two values: publishable (pk-) + secret (sk-) — both required.
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# OPTIONAL — toggles & defaults (safe defaults provided; override only if needed)
# =============================================================================

# Default models (model abstraction layer reads these)
LLM_MODEL_CLASSIFY=claude-haiku-4-5-20251001
LLM_MODEL_SYNTHESIZE=claude-sonnet-4-6
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# n8n webhook base URL (for triggering Scenario A manually + Scenario B from Airtable,
# and for the test_scenario_b.py harness). Both names supported; prefer the _URL form.
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.app.n8n.cloud/webhook
# Backwards-compat alias (do not need to set both):
# N8N_WEBHOOK_BASE=https://your-n8n-instance.app.n8n.cloud/webhook

# Run mode (dev disables Slack posts and writes to a sandbox channel)
RUN_MODE=dev
